# Server
PORT=8080
ENV=development

# Database
DATABASE_URL=postgres://admin:secret@localhost:5432/nats_admin?sslmode=disable

# NATS
NATS_URL=nats://localhost:4222
RESOLVER_DIR=/data/nats/resolver

# NATS Auth (generated by: nats-admin bootstrap)
OPERATOR_SEED=
SYSTEM_ACCOUNT_SEED=

# Encryption (AES-256-GCM, 32 bytes hex)
# Generate: openssl rand -hex 32
MASTER_KEY=

# Admin Web JWT (at least 32 bytes hex)
# Generate: openssl rand -hex 32
JWT_SECRET=
JWT_EXPIRY=24h

# Bootstrap Admin User
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=changeme
